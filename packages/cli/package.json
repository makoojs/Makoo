{
  "name": "@makoojs/cli",
  "version": "0.2.0",
  "description": "CLI and Vite integration for the Makoo userscript development framework",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/makoojs/Makoo.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/makoojs/Makoo#readme",
  "bugs": {
    "url": "https://github.com/makoojs/Makoo/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "makoo": "./dist/bin.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./monkey": {
      "types": "./dist/monkey/index.d.ts",
      "import": "./dist/monkey/index.js",
      "require": "./dist/monkey/index.cjs"
    }
  },
  "dependencies": {
    "@makoojs/core": "workspace:*",
    "jiti": "^2.6.1",
    "picomatch": "^4.0.4",
    "vite-plugin-monkey": "^7.1.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/picomatch": "^4.0.3",
    "cac": "^7.0.0"
  },
  "peerDependencies": {
    "vite": ">=7"
  }
}

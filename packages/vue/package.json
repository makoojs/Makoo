{
  "name": "@rite/vue",
  "version": "1.3.1",
  "description": "Vue adapter and compatibility injector for rite",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "dependencies": {
    "@rite/core": "workspace:*"
  },
  "peerDependencies": {
    "vue": ">=3"
  }
}

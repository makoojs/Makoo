{
  "name": "@makoojs/vue",
  "version": "0.1.0",
  "description": "Vue adapter for the Makoo userscript development framework",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/makoojs/Makoo.git",
    "directory": "packages/vue"
  },
  "homepage": "https://github.com/makoojs/Makoo#readme",
  "bugs": {
    "url": "https://github.com/makoojs/Makoo/issues"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "dependencies": {
    "@makoojs/core": "workspace:*"
  },
  "devDependencies": {
    "vue": "^3.5.35"
  },
  "peerDependencies": {
    "vue": ">=3"
  }
}

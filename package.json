{
  "name": "makoo",
  "version": "1.3.1",
  "private": true,
  "description": "A Vue 3 component injection framework for userscripts",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FlowingInk/makoo.git"
  },
  "homepage": "https://github.com/FlowingInk/makoo#readme",
  "bugs": {
    "url": "https://github.com/FlowingInk/makoo/issues"
  },
  "keywords": [
    "vue",
    "vue3",
    "injector",
    "component-injection",
    "userscript",
    "tampermonkey",
    "greasemonkey",
    "dom",
    "typescript"
  ],
  "scripts": {
    "build": "pnpm build:packages",
    "build:core": "vite build --config packages/core/vite.config.ts",
    "build:vue": "vite build --config packages/vue/vite.config.ts",
    "build:react": "vite build --config packages/react/vite.config.ts",
    "build:cli": "vite build --config packages/cli/vite.config.ts",
    "build:packages": "pnpm build:core && pnpm build:vue && pnpm build:react && pnpm build:cli",
    "demo:dev": "vite --config vite.demo.config.ts",
    "demo:build": "vite build --config vite.demo.config.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:fix-unsafe": "biome check --write --unsafe .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^28.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "~5.9.3",
    "vite": "^8.0.0-beta.13",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-monkey": "^7.1.9",
    "vitest": "^4.0.18",
    "vue": "^3.5.29",
    "vue-tsc": "^3.1.5"
  },
  "overrides": {
    "vite": "^8.0.0-beta.13"
  }
}
